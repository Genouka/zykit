<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zykit.App.ViewModels"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="Zykit.App.Views.ProfileView"
             x:DataType="vm:ProfileViewModel">

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="20">
            <TextBlock Text="Profile管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBlock Text="管理调试和发布Profile，安装应用时会自动创建Profile，通常无需手动操作" Opacity="0.5" Margin="0,0,0,10" />

            <!-- 统一Profile列表（置顶） -->
            <suki:GlassCard>
                <StackPanel Margin="20" Spacing="12">
                    <TextBlock Text="Profile列表" FontSize="16" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding RefreshUnifiedListCommand}" IsEnabled="{Binding !IsLoading}" Padding="10,8" ToolTip.Tip="刷新列表">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DownloadProfileCommand}" Padding="10,8" ToolTip.Tip="下载到本地">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                                <TextBlock Text="下载" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteProfileCommand}" Padding="10,8" ToolTip.Tip="删除">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                <TextBlock Text="删除" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearExpiredCommand}" Padding="10,8" ToolTip.Tip="清理过期">
                            <PathIcon Data="M15 16h4v2h-4zm0-8h7v2h-7zm0 4h6v2h-6zM3 18c0 1.1.9 2 2 2h6c1.1 0 2-.9 2-2V8H3v10zM14 4h-3l-1-1H6L5 4H2v2h12V4z" />
                        </Button>
                    </StackPanel>
                    <DataGrid x:Name="ProfileGrid" ItemsSource="{Binding UnifiedProfiles}" SelectedItem="{Binding SelectedProfile}"
                              SelectionMode="Extended"
                              IsReadOnly="True" AutoGenerateColumns="False" MinHeight="150"
                              GridLinesVisibility="All" BorderThickness="1"
                              DoubleTapped="ProfileGrid_DoubleTapped">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制选中行" Click="CopySelected_Click" />
                                <MenuItem Header="复制">
                                    <MenuItem Header="AppId" Click="CopyCell_Click" Tag="AppId" />
                                    <MenuItem Header="名称" Click="CopyCell_Click" Tag="Name" />
                                    <MenuItem Header="Profile ID" Click="CopyCell_Click" Tag="CloudId" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="下载" Command="{Binding DownloadProfileCommand}" />
                                <MenuItem Header="删除" Command="{Binding DeleteProfileCommand}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding SourceIcon}" Width="60" />
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="类型" Binding="{Binding TypeName}" Width="100" />
                            <DataGridTextColumn Header="AppId" Binding="{Binding AppId}" Width="150" />
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusDisplay}" Width="80" />
                            <DataGridTextColumn Header="过期" Binding="{Binding ExpiresDisplay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </suki:GlassCard>

            <!-- 创建Profile（折叠） -->
            <suki:GlassCard>
                <StackPanel Margin="20" Spacing="12">
                    <CheckBox IsChecked="{Binding ShowCreateProfileForm}" Content="创建新Profile" Opacity="0.8" FontWeight="SemiBold" />
                    <TextBlock IsVisible="{Binding !ShowCreateProfileForm}" Text="点击上方勾选展开Profile创建表单" Opacity="0.4" FontSize="12" />

                    <StackPanel IsVisible="{Binding ShowCreateProfileForm}" Spacing="12">
                        <TextBlock Text="{Binding ProfileFormHint}" Opacity="0.6" TextWrapping="Wrap" />

                        <!-- 加载资源 -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding LoadCloudResourcesCommand}" Padding="10,8" ToolTip.Tip="加载云端证书和设备列表">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                                    <TextBlock Text="加载云端资源" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding FetchDeviceFromUsbCommand}" Padding="10,8" ToolTip.Tip="从已连接的USB设备自动获取并选中云端设备">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z" />
                                    <TextBlock Text="从设备获取" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AutoFillProfileFormCommand}" Padding="10,8" ToolTip.Tip="填入推荐默认值">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                    <TextBlock Text="默认" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- 包名 -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="包名:" VerticalAlignment="Center" Width="70" />
                            <TextBox Text="{Binding PackageName}" MinWidth="250" PlaceholderText="com.example.app (必填)" />
                        </StackPanel>

                        <!-- AppId查询 -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="AppId:" VerticalAlignment="Center" Width="70" />
                            <TextBox Text="{Binding AppId}" MinWidth="180" PlaceholderText="必填，可点击查询自动填入" />
                            <Button Command="{Binding QueryAppIdCommand}" Padding="10,8" ToolTip.Tip="根据包名查询AppId">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                                    <TextBlock Text="查询" />
                                </StackPanel>
                            </Button>
                            <ComboBox ItemsSource="{Binding AppIds}" SelectedItem="{Binding SelectedAppId}" MinWidth="150" DisplayMemberBinding="{Binding AppId}" PlaceholderText="查询结果" />
                        </StackPanel>
                        <TextBlock Text="AppId是创建Profile的必填项。如果查询不到，需要先在AGC网站上创建应用" Opacity="0.5" FontSize="12" TextWrapping="Wrap" />
                        <Button Command="{Binding OpenCreateAppUrlCommand}" Padding="10,6" HorizontalAlignment="Left" ToolTip.Tip="在浏览器中打开AGC网站">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                                <TextBlock Text="前往AGC创建应用" />
                            </StackPanel>
                        </Button>

                        <!-- Profile名称 -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="名称:" VerticalAlignment="Center" Width="70" />
                            <TextBox Text="{Binding ProvisionName}" MinWidth="250" PlaceholderText="可选，留空自动生成" />
                        </StackPanel>

                        <!-- 证书选择 -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="证书:" VerticalAlignment="Center" Width="70" />
                            <ComboBox ItemsSource="{Binding CloudCerts}" SelectedItem="{Binding SelectedCert}" MinWidth="250" DisplayMemberBinding="{Binding CertName}" />
                        </StackPanel>

                        <!-- Profile类型 -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="类型:" VerticalAlignment="Center" Width="70" />
                            <ComboBox SelectedIndex="{Binding ProvisionType}" MinWidth="150">
                                <ComboBoxItem Content="调试Profile" />
                                <ComboBoxItem Content="发布Profile" />
                            </ComboBox>
                        </StackPanel>

                        <!-- 设备选择 -->
                        <TextBlock Text="绑定设备（可选，调试Profile建议选择）" Opacity="0.5" Margin="0,5,0,0" />
                        <ListBox ItemsSource="{Binding CloudDevices}" MinHeight="80" MaxHeight="200"
                                 SelectionMode="Multiple">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DeviceName}" />
                                        <TextBlock Text="{Binding Udid}" Opacity="0.5" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- ACL权限 -->
                        <TextBlock Text="ACL权限（可选，按需勾选）" Opacity="0.5" Margin="0,5,0,0" />
                        <ItemsControl ItemsSource="{Binding AvailableAclPermissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding}" Margin="0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Command="{Binding CreateProfileCommand}" IsEnabled="{Binding !IsCreating}" Padding="12,8" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                <TextBlock Text="创建Profile" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </suki:GlassCard>

            <TextBlock Text="{Binding OperationStatus}" Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>

</UserControl>
